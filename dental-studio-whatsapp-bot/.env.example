# =============================================================================
# Evolution API
# =============================================================================

# Public URL where Evolution API is reachable (used by n8n to send replies)
SERVER_URL=https://evolution.yourdomain.com

# Master API key for Evolution API — set this to a strong random string
AUTHENTICATION_API_KEY=YOUR_EVOLUTION_API_KEY

# =============================================================================
# Database (PostgreSQL — shared by Evolution API and n8n)
# =============================================================================

# Full connection URI for PostgreSQL
DATABASE_CONNECTION_URI=postgresql://postgres:YOUR_DB_PASSWORD@postgres:5432/evolution

# =============================================================================
# Redis
# =============================================================================

# Redis connection URI — used for debounce buffer and session state
CACHE_REDIS_URI=redis://redis:6379/1

# =============================================================================
# n8n
# =============================================================================

# Hostname where n8n is served (used to build webhook URLs)
N8N_HOST=n8n.yourdomain.com

# Full webhook URL that Evolution API will POST messages to
# Must match the path configured in your n8n workflow trigger node
WEBHOOK_URL=https://n8n.yourdomain.com/webhook/whatsapp-triage

# Encryption key for n8n credential storage — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=YOUR_N8N_ENCRYPTION_KEY

# =============================================================================
# Google Gemini
# =============================================================================

# Gemini API key from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# =============================================================================
# Traefik (HTTPS / Let's Encrypt)
# =============================================================================

# Email used for Let's Encrypt certificate registration
TRAEFIK_ACME_EMAIL=your-email@example.com
